rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Datos del usuario (equipos, jugadores, sesiones, etc.)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Configuración pública (solo lectura)
    match /config/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Clubes y equipos de club
    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      
      match /teams/{teamId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid ||
          (resource != null && request.auth.uid in resource.data.assignedCoaches)
        );
        allow write: if request.auth != null && (
          get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid
        );
        
        // Subcolecciones dentro de equipos del club (players, sessions, matches, etc.)
        match /{document=**} {
          allow read, write: if request.auth != null && (
            get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid ||
            request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubId)/teams/$(teamId)).data.assignedCoaches
          );
        }
      }
    }

    // Planes compartidos con jugadores
    match /sharedPlans/{planId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Invitaciones de club
    match /invitations/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Consentimientos digitales firmados por los padres
    match /consents/{consentId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Stripe: colección customers (necesaria para la extensión Firebase Stripe)
    // El usuario solo puede leer/escribir su propio documento y subcolecciones
    match /customers/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // checkout_sessions: el usuario crea la sesión, la extensión la actualiza
      match /checkout_sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // subscriptions: la extensión escribe aquí — solo lectura para el usuario
      match /subscriptions/{subscriptionId} {
        allow read: if request.auth != null && request.auth.uid == uid;
      }

      // payments: solo lectura para el usuario
      match /payments/{paymentId} {
        allow read: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
