rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // APK público: lectura libre, escritura temporal abierta para deploy de release
    match /mister11.apk {
      allow read: if true;
      allow write: if true; // TEMPORAL: se restaura después del upload v1.1.11
    }







    // Resto de archivos: solo usuarios autenticados
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
