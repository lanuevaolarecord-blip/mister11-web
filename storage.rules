rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // APK público: cualquiera puede leer, escritura permitida sin auth (solo para subida admin)
    match /mister11.apk {
      allow read: if true;
      allow write: if true;
    }
    // Resto de archivos: solo usuarios autenticados
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
