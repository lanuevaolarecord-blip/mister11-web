rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // APK público: cualquiera puede leer, escritura solo para desarrolladores autorizados
    match /mister11.apk {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in [
        'mister11.app@gmail.com',
        'lanuevaolarecord@gmail.com',
        'jhocao111294@gmail.com',
        'lavozdelformador@gmail.com'
      ];
    }






    // Resto de archivos: solo usuarios autenticados
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
